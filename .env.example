# EarthPulse — Backend Environment Variables
# Copy to `.env` (project root) and fill in values.
# `.env` is gitignored; this file is committed as a reference template.
# Loaded by backend/config.py via pydantic-settings.

# ── Server ───────────────────────────────────────────────────────────────────

# Set to false in production (already the default in config.py)
DEBUG=false

# CORS allowed origins — JSON array (must match your deployed frontend URL)
# Example: CORS_ORIGINS=["https://earthpulse.pages.dev","https://yourdomain.com"]
# Local dev default: http://localhost:5173 (no change needed for local)
CORS_ORIGINS=["http://localhost:5173"]

# ── P0 API Keys (required for full functionality) ────────────────────────────

# 1. NASA FIRMS — fire hotspots on Earth Now globe
#    Register (free, instant): https://firms.modaps.eosdis.nasa.gov/api/map_key/
#    Rate limit: 5,000 transactions / 10 min
FIRMS_MAP_KEY=

# 2. AirNow — current AQI for Local Reports Block 1
#    Register (free): https://docs.airnowapi.org/
#    Rate limit: 500 req/hr per endpoint
AIRNOW_API_KEY=

# 3. OpenAQ v3 — global air quality monitors on Earth Now globe
#    Register (free): https://explore.openaq.org/
#    Rate limit: 2,000 req/hr
OPENAQ_API_KEY=

# ── P1 API Keys (needed for upcoming features — register early) ───────────────

# 4. EPA AQS — annual PM2.5 / ozone trend data (Local Reports Block 1 annual)
#    Registration: https://aqs.epa.gov/aqsweb/documents/data_api.html
#    (email + key pair; 10 req/min limit)
EPA_AQS_EMAIL=
EPA_AQS_KEY=

# 5. Copernicus ADS — CAMS smoke / aerosol forecast layer on globe
#    Registration: https://cds.climate.copernicus.eu/
#    (requires manual account approval; free tier)
CAMS_ADS_KEY=

# ── Infrastructure (Phase 2 — not yet wired) ─────────────────────────────────

# DATABASE_URL=postgresql+asyncpg://user:pass@host/earthpulse
# REDIS_URL=redis://localhost:6379/0

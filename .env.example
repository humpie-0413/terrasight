# Backend configuration — copy to `.env` (project root) and fill in.
# `.env` is gitignored; `.env.example` stays committed as a template.
# Loaded by backend/config.py via pydantic-settings (env_file=".env").

# -------- External API keys --------

# NASA FIRMS MAP_KEY (free, instant)
# Register: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Used by: backend/connectors/firms.py → /api/earth-now/fires
FIRMS_MAP_KEY=

# AirNow API key (free)
# Register: https://docs.airnowapi.org/
AIRNOW_API_KEY=

# OpenAQ v3 API key (free)
# Register: https://explore.openaq.org/
OPENAQ_API_KEY=

# -------- Infrastructure --------

# DATABASE_URL=postgresql+asyncpg://localhost/earthpulse
# REDIS_URL=redis://localhost:6379/0

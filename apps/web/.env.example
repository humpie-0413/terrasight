# -----------------------------------------------------------------------------
# TerraSight web — environment configuration (example).
# Copy to `.env` for local dev; do NOT commit `.env`.
# -----------------------------------------------------------------------------

# Worker base URL for /api/* calls from the browser.
# - Dev (astro dev + wrangler dev on :8787): point at the local Worker.
# - Prod: leave EMPTY — both app and Worker serve from the same origin.
PUBLIC_WORKER_BASE_URL=http://localhost:8787

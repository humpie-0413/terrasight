---
/**
 * Per-city environmental report page.
 *
 * ## Data-mirror strategy
 * Astro/Vite cannot reliably import JSON from outside the `apps/web/` tree,
 * so Step 7 mirrors the pipeline output from `data/reports/*.json` (repo
 * root) into `apps/web/src/data/reports/*.json`. That mirror is the
 * build-time fixture; the canonical source of truth remains the repo-root
 * files, which are regenerated by the pipeline. A follow-up task in Step 7
 * will automate the mirror in the build script.
 *
 * ## Canonical links
 * Per the Rule 7 user decision, a `<link rel="canonical">` tag is emitted
 * **only** when `PUBLIC_SITE_URL` is set at build time. Dev / preview
 * environments skip it rather than shipping a wrong absolute URL.
 *
 * ## Methodology ordering
 * The Methodology block is always present in `blocks[]` and always has
 * `status: 'ok'`, but we extract it via `partitionBlocks` and append it
 * LAST in the main column — after every core and embedded-optional block.
 * The `blocks[]` natural order is preserved for everything else.
 *
 * ## Block dispatch (do not hardcode ids here)
 * Ids come from `@terrasight/schemas::CoreBlockId` / `OptionalBlockId`,
 * re-exported via `../../lib/reports.ts::CORE_BLOCK_IDS` /
 * `EMBEDDABLE_OPTIONAL_IDS`. Adding a new block id requires changes
 * there — never inline the literal here.
 */
import Layout from '../../layouts/BaseLayout.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import {
  BlockRenderer,
  AdSlot,
  CityComparison,
  RelatedCities,
  RankingsSnippet,
} from '../../components/reports';
import {
  partitionBlocks,
  buildJsonLdArticle,
  buildJsonLdBreadcrumb,
  buildJsonLdDataset,
} from '../../lib/reports';
import reportsIndexRaw from '../../data/reports-index.json';
import type { CityReport, CityReportIndex } from '@terrasight/schemas';

export async function getStaticPaths() {
  // Eagerly import every mirrored report JSON so we know which slugs are
  // actually buildable. If the index references a slug whose JSON has not
  // been mirrored yet, we skip it (Rule 5: graceful degradation — never
  // crash the build on a missing downstream file).
  const reportModules = import.meta.glob<CityReport>(
    '../../data/reports/*.json',
    { eager: true, import: 'default' },
  );
  const availableSlugs = new Set(
    Object.keys(reportModules).map((p) => {
      const file = p.split('/').pop() ?? '';
      return file.replace(/\.json$/, '');
    }),
  );

  const index = reportsIndexRaw as unknown as CityReportIndex;
  const paths: Array<{ params: { slug: string } }> = [];
  for (const entry of index.reports) {
    if (!availableSlugs.has(entry.slug)) {
      // eslint-disable-next-line no-console
      console.warn(
        `[reports/[...slug]] Skipping slug "${entry.slug}" — no mirrored JSON ` +
          `at apps/web/src/data/reports/${entry.slug}.json. Re-run the data mirror step.`,
      );
      continue;
    }
    paths.push({ params: { slug: entry.slug } });
  }
  return paths;
}

const { slug } = Astro.params;

// Re-run the glob inside the page scope to resolve the exact module we
// need. `eager: true` ensures these are inlined at build time, not
// resolved lazily at runtime (we are SSG — there is no runtime).
const reportModules = import.meta.glob<CityReport>(
  '../../data/reports/*.json',
  { eager: true, import: 'default' },
);
const reportBySlug: Record<string, CityReport> = {};
for (const [path, mod] of Object.entries(reportModules)) {
  const file = path.split('/').pop() ?? '';
  const key = file.replace(/\.json$/, '');
  reportBySlug[key] = mod as CityReport;
}

const report = slug ? reportBySlug[slug] : undefined;

// Rule 5: missing report module → clean 404 card, never a 500.
if (!report) {
  // Astro will still emit the page; we render a minimal "not found" body.
}

const SITE_URL: string | null = (import.meta.env.PUBLIC_SITE_URL as string | undefined) ?? null;

// ---- JSON-LD (only when we have a valid report) ----
const jsonLdArticle = report ? buildJsonLdArticle(report, SITE_URL) : null;
const jsonLdBreadcrumb = report ? buildJsonLdBreadcrumb(report, SITE_URL) : null;
const jsonLdDataset = report ? buildJsonLdDataset(report, SITE_URL) : null;

// ---- Block partition (core minus methodology, embedded optionals, methodology) ----
const partitioned = report ? partitionBlocks(report) : null;

// Use a stable insertion point for the mid-column ad: after the Air Quality block.
// If Air Quality is missing (shouldn't happen — it's core), we fall through
// and skip the ad entirely.
const coreBlocks = partitioned?.coreBlocks ?? [];
const airQualityIdx = coreBlocks.findIndex((b) => b.id === 'air_quality');

// Agent 2 will wire `city_comparison` between the final core block and
// methodology — when their `CityComparison.astro` lands, replace the
// inline placeholder with the real import.

const pageTitle = report ? `${report.city} — Environmental Report` : 'Report not found';
const pageDescription = report
  ? report.summary.headline
  : 'Requested city report was not available at build time.';
const canonicalUrl = SITE_URL && report ? `${SITE_URL.replace(/\/$/, '')}/reports/${report.slug}` : null;
---

<Layout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}
    {jsonLdArticle ? (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(jsonLdArticle)}
      />
    ) : null}
    {jsonLdBreadcrumb ? (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(jsonLdBreadcrumb)}
      />
    ) : null}
    {jsonLdDataset ? (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(jsonLdDataset)}
      />
    ) : null}
  </Fragment>

  <main id="main" class="report-page">
    {!report ? (
      <section class="ts-container report-404">
        <h1 class="report-404__title">Report not available</h1>
        <p class="report-404__body">
          We could not find a report for <code>{slug}</code>. It may have been
          removed or the pipeline has not yet generated it.
        </p>
        <p class="report-404__cta">
          <a href="/reports">← Back to all reports</a>
        </p>
      </section>
    ) : (
      <>
        {/* ----- Hero ----- */}
        <header class="report-hero">
          <div class="ts-container">
            <p class="report-hero__crumbs">
              <a href="/">Home</a>
              <span aria-hidden="true"> / </span>
              <a href="/reports">Reports</a>
              <span aria-hidden="true"> / </span>
              <span class="report-hero__crumbs-current">{report.city}</span>
            </p>
            <h1 class="report-hero__title">{report.city}</h1>
            <p class="report-hero__subtitle">
              {report.region} · CBSA {report.cbsaCode}
            </p>
            <ul class="report-hero__badges">
              {report.climateZone ? (
                <li class="report-hero__badge report-hero__badge--climate">
                  {report.climateZone}
                </li>
              ) : null}
              {report.coastal ? (
                <li class="report-hero__badge report-hero__badge--coastal">
                  Coastal
                </li>
              ) : null}
              {report.population ? (
                <li class="report-hero__badge report-hero__badge--pop">
                  Pop.{' '}
                  {report.population.toLocaleString()}
                  {report.populationYear ? ` (${report.populationYear})` : ''}
                </li>
              ) : null}
            </ul>
          </div>
        </header>

        {/* ----- Summary lede ----- */}
        <section class="report-summary ts-container" aria-labelledby="report-summary-title">
          <h2 id="report-summary-title" class="report-summary__sr">Summary</h2>
          <p class="report-summary__headline">{report.summary.headline}</p>
          {report.summary.bullets.length > 0 ? (
            <ul class="report-summary__bullets">
              {report.summary.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          ) : null}
        </section>

        {/* ----- Ad slot #1: hero ----- */}
        <div class="ts-container report-ad-row">
          <AdSlot slot="report-hero" />
        </div>

        {/* ----- Main + sidebar grid ----- */}
        <div class="ts-container report-grid">
          <section class="report-main" aria-label="Environmental report body">
            {coreBlocks.map((block, i) => [
              <BlockRenderer block={block} />,
              i === airQualityIdx && airQualityIdx !== -1 ? (
                <AdSlot slot="report-mid" />
              ) : null,
            ])}

            {/*
              Embedded optional blocks (pfas_monitoring, coastal_conditions,
              disaster_history_detailed) — only those already filtered by
              partitionBlocks (availability === 'included') reach here.
            */}
            {partitioned?.embeddedOptionals.map((block) => (
              <BlockRenderer block={block} />
            ))}

            {/*
              city_comparison is always external (never embedded — Step 5
              policy). The CityComparison card links out to /rankings/*.
            */}
            <CityComparison report={report} />

            {/* Methodology is always last. */}
            {partitioned?.methodology ? (
              <BlockRenderer block={partitioned.methodology} />
            ) : null}
          </section>

          <aside class="report-sidebar" aria-label="Related information">
            <RelatedCities report={report} />
            <RankingsSnippet report={report} />
          </aside>
        </div>

        {/* ----- Ad slot #3: footer ----- */}
        <div class="ts-container report-ad-row">
          <AdSlot slot="report-footer" />
        </div>
      </>
    )}
  </main>

  <SiteFooter generatedAt={report?.meta.build.generatedAt ?? (reportsIndexRaw as unknown as CityReportIndex).generatedAt} />
</Layout>

<style>
  .report-page {
    padding-bottom: 48px;
  }

  /* 404 fallback */
  .report-404 {
    padding: 72px 24px;
    text-align: center;
  }
  .report-404__title {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 12px;
  }
  .report-404__body {
    font-size: 1rem;
    color: #64748b;
    max-width: 460px;
    margin: 0 auto 18px;
    line-height: 1.55;
  }
  .report-404__body code {
    background: #f1f5f9;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9rem;
  }
  .report-404__cta a {
    color: #1d4ed8;
    text-decoration: underline;
    font-weight: 600;
  }

  /* Hero */
  .report-hero {
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    padding: 48px 0 32px;
    border-bottom: 1px solid #e2e8f0;
  }
  .report-hero__crumbs {
    font-size: 0.8125rem;
    color: #64748b;
    margin: 0 0 12px;
  }
  .report-hero__crumbs a {
    color: #1d4ed8;
    text-decoration: none;
  }
  .report-hero__crumbs a:hover { text-decoration: underline; }
  .report-hero__crumbs-current {
    color: #0f172a;
    font-weight: 500;
  }
  .report-hero__title {
    font-size: 2.25rem;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.02em;
    margin: 0 0 6px;
    line-height: 1.15;
  }
  .report-hero__subtitle {
    font-size: 1rem;
    color: #475569;
    margin: 0 0 14px;
  }
  .report-hero__badges {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .report-hero__badge {
    display: inline-flex;
    align-items: center;
    height: 22px;
    padding: 0 10px;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    background: #f1f5f9;
    color: #475569;
    border: 1px solid #e2e8f0;
  }
  .report-hero__badge--climate {
    background: #eff6ff;
    color: #1d4ed8;
    border-color: #bfdbfe;
  }
  .report-hero__badge--coastal {
    background: #ecfeff;
    color: #0e7490;
    border-color: #a5f3fc;
  }
  .report-hero__badge--pop {
    background: #f1f5f9;
    color: #0f172a;
  }

  /* Summary */
  .report-summary {
    padding: 32px 24px 0;
  }
  .report-summary__sr {
    position: absolute;
    width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }
  .report-summary__headline {
    font-size: 1.125rem;
    color: #0f172a;
    line-height: 1.55;
    margin: 0 0 14px;
  }
  .report-summary__bullets {
    margin: 0;
    padding: 0 0 0 20px;
    color: #334155;
    font-size: 0.9375rem;
    line-height: 1.65;
  }
  .report-summary__bullets li + li {
    margin-top: 4px;
  }

  /* Ad slots */
  .report-ad-row {
    padding: 24px;
  }
  .report-ad-slot {
    min-height: 120px;
    border: 1px dashed #cbd5e1;
    border-radius: 12px;
    background: #f8fafc;
    color: #94a3b8;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 20px 0;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .report-ad-slot__label {
    color: #94a3b8;
  }

  /* Grid */
  .report-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 40px;
    padding: 16px 24px 0;
  }
  @media (max-width: 900px) {
    .report-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 32px;
    }
  }

  .report-main {
    min-width: 0;
  }
  .report-sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Placeholders (pending Agent 2 components) */
  .report-placeholder {
    border: 1px dashed #cbd5e1;
    border-radius: 12px;
    padding: 16px;
    background: #f8fafc;
  }
  .report-placeholder__label {
    font-size: 0.75rem;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 6px;
  }
  .report-placeholder__body {
    font-size: 0.8125rem;
    color: #94a3b8;
    margin: 0;
    line-height: 1.5;
  }
  .report-placeholder__body code {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    padding: 1px 5px;
    font-size: 0.75rem;
  }
</style>

---
/**
 * /guides — Guides index.
 *
 * Pure Astro SSG. Lists the 4 guide stubs. This page IS indexable
 * (no noindex meta), but every individual guide stub is `noindex,
 * nofollow` until content is written.
 */
import Layout from '../../layouts/BaseLayout.astro';
import SiteFooter from '../../components/SiteFooter.astro';

interface GuideEntry {
  slug: string;
  title: string;
  intro: string;
}

const GUIDES: GuideEntry[] = [
  {
    slug: 'what-is-a-trust-tag',
    title: 'What is a trust tag?',
    intro:
      'The 5-enum vocabulary (observed / near-real-time / forecast / derived / compliance) that appears on every value across TerraSight.',
  },
  {
    slug: 'how-to-read-a-report',
    title: 'How to read a local environmental report',
    intro:
      'A tour of the 8 core blocks: air quality, climate locally, hazards & disasters, water, industrial emissions, site cleanup, population exposure, and methodology.',
  },
  {
    slug: 'why-compliance-is-not-exposure',
    title: 'Why compliance is not exposure',
    intro:
      'Regulatory counts (ECHO, SDWIS) track reporting activity, not health outcomes. The mandatory disclaimer that shows up on every relevant page, explained.',
  },
  {
    slug: 'finding-local-environmental-data',
    title: 'Finding local environmental data',
    intro:
      'A navigation hub linking reports, rankings, the globe, and the atlas for environmental engineers, students, and curious locals.',
  },
];

const generatedAt = new Date().toISOString();
---

<Layout
  title="Guides — TerraSight"
  description="Short, source-linked explainers for how TerraSight tags, reports, and ranks environmental data across U.S. metros."
  seo={{
    title: 'Guides — TerraSight',
    description:
      'Short, source-linked explainers for how TerraSight tags, reports, and ranks environmental data across U.S. metros.',
    path: '/guides',
  }}
>
  <main id="main" class="guides-index">
    <header class="guides-index__hero">
      <div class="ts-container">
        <p class="guides-index__crumbs">
          <a href="/">Home</a>
          <span aria-hidden="true"> / </span>
          <span class="guides-index__crumbs-current">Guides</span>
        </p>
        <h1 class="guides-index__title">Guides</h1>
        <p class="guides-index__lede">
          How to read a TerraSight report, what a trust tag means, and why
          compliance counts are not the same as exposure. These explainers
          are under active writing — each stub currently links back here.
        </p>
      </div>
    </header>

    <section class="guides-index__list-wrap ts-container" aria-labelledby="guides-list-title">
      <h2 id="guides-list-title" class="guides-index__sr">Guide stubs</h2>
      <ul class="guides-index__list">
        {GUIDES.map((g) => (
          <li class="guides-index__item">
            <a
              class="guide-row"
              href={`/guides/${g.slug}`}
              data-link-type="internal"
              data-target-section="guides"
            >
              <span class="guide-row__badge">Draft</span>
              <h3 class="guide-row__title">{g.title}</h3>
              <p class="guide-row__intro">{g.intro}</p>
            </a>
          </li>
        ))}
      </ul>

      <p class="guides-index__note">
        Guide content is being written. Each stub page currently carries a
        <code>noindex, nofollow</code> meta tag — they will not appear in
        search results until their bodies ship.
      </p>
    </section>
  </main>

  <SiteFooter generatedAt={generatedAt} />
</Layout>

<style>
  .guides-index { padding-bottom: 48px; }

  .guides-index__sr {
    position: absolute;
    width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  .guides-index__hero {
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    padding: 48px 0 40px;
    border-bottom: 1px solid #e2e8f0;
  }
  .guides-index__crumbs {
    font-size: 0.8125rem;
    color: #64748b;
    margin: 0 0 12px;
  }
  .guides-index__crumbs a { color: #1d4ed8; text-decoration: none; }
  .guides-index__crumbs a:hover { text-decoration: underline; }
  .guides-index__crumbs-current { color: #0f172a; font-weight: 500; }
  .guides-index__title {
    font-size: 2.25rem;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }
  .guides-index__lede {
    font-size: 1rem;
    color: #475569;
    max-width: 680px;
    margin: 0;
    line-height: 1.55;
  }

  .guides-index__list-wrap {
    padding: 32px 24px 0;
  }

  .guides-index__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }
  .guides-index__item { display: block; }

  .guide-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 18px;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    background: #ffffff;
    text-decoration: none;
    color: inherit;
    transition: transform 120ms ease, border-color 120ms ease, box-shadow 120ms ease;
    height: 100%;
  }
  .guide-row:hover {
    transform: translateY(-2px);
    border-color: #cbd5e1;
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
  }
  .guide-row__badge {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #78350f;
    background: #fef3c7;
    padding: 2px 8px;
    border-radius: 9999px;
    text-transform: uppercase;
    align-self: flex-start;
  }
  .guide-row__title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.3;
    margin: 4px 0 0;
  }
  .guide-row__intro {
    font-size: 0.8125rem;
    color: #475569;
    margin: 0;
    line-height: 1.55;
  }

  .guides-index__note {
    margin: 32px 0 0;
    padding: 14px 16px;
    background: #f8fafc;
    border: 1px dashed #cbd5e1;
    border-radius: 8px;
    font-size: 0.8125rem;
    color: #64748b;
    line-height: 1.55;
  }
  .guides-index__note code {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    padding: 1px 6px;
    font-size: 0.75rem;
  }
</style>

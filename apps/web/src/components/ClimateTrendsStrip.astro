---
import { TrustBadge } from '@terrasight/ui';
import type { TrustTag } from '@terrasight/schemas';

// TrustBadge is React, but we render it WITHOUT client:* so Astro
// serializes the output to plain HTML at build time. Zero JS ships
// to the home page for this strip.

export interface TrendCard {
  id: string;
  title: string;
  value: string;
  unit: string;
  deltaLabel: string;
  deltaDirection: 'up-bad' | 'down-bad' | 'up-good' | 'down-good' | 'neutral';
  cadence: string;
  trustTag: TrustTag;
  source: string;
  sourceUrl: string;
  caveat: string;
}

export interface Props {
  trends: {
    generatedAt: string;
    source: string;
    cards: TrendCard[];
  };
}

const { trends } = Astro.props;

function deltaArrow(dir: TrendCard['deltaDirection']): string {
  switch (dir) {
    case 'up-bad':
    case 'up-good':
      return '▲';
    case 'down-bad':
    case 'down-good':
      return '▼';
    default:
      return '·';
  }
}

function deltaClass(dir: TrendCard['deltaDirection']): string {
  if (dir === 'up-bad' || dir === 'down-bad') return 'trend-card__delta--bad';
  if (dir === 'up-good' || dir === 'down-good') return 'trend-card__delta--good';
  return 'trend-card__delta--neutral';
}
---

<section class="trends" aria-labelledby="trends-title">
  <div class="ts-container">
    <header class="trends__header">
      <h2 id="trends-title" class="trends__title">Climate Trends</h2>
      <p class="trends__subtitle">
        The three big-picture signals: carbon, temperature, ice.
        Placeholder values shown — connectors land in a later step.
      </p>
    </header>

    <div class="trends__grid" role="list">
      {trends.cards.map((card) => (
        <article class="trend-card" role="listitem" aria-labelledby={`trend-${card.id}-title`}>
          <p class="trend-card__eyebrow">{card.cadence} · placeholder</p>
          <h3 id={`trend-${card.id}-title`} class="trend-card__title">{card.title}</h3>

          <div class="trend-card__value-row">
            <span class="trend-card__value">{card.value}</span>
            <span class="trend-card__unit">{card.unit}</span>
          </div>

          <p class={`trend-card__delta ${deltaClass(card.deltaDirection)}`}>
            <span aria-hidden="true" class="trend-card__delta-arrow">{deltaArrow(card.deltaDirection)}</span>
            <span>{card.deltaLabel}</span>
          </p>

          <div class="trend-card__meta">
            <TrustBadge tag={card.trustTag} />
            <a
              class="trend-card__source"
              href={card.sourceUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Source: {card.source}
            </a>
          </div>

          <p class="trend-card__caveat">{card.caveat}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .trends {
    padding: 72px 0 64px;
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
  }
  .trends__header {
    margin-bottom: 32px;
    max-width: 680px;
  }
  .trends__title {
    font-size: 24px;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.01em;
    margin: 0 0 8px;
  }
  .trends__subtitle {
    font-size: 14px;
    color: #64748b;
    margin: 0;
  }
  .trends__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
  }
  .trend-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 4px 12px rgba(15, 23, 42, 0.04);
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
  }
  .trend-card__eyebrow {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #94a3b8;
    margin: 0;
    font-weight: 600;
  }
  .trend-card__title {
    font-size: 15px;
    font-weight: 600;
    color: #0f172a;
    margin: 0;
  }
  .trend-card__value-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 2px;
  }
  .trend-card__value {
    font-size: 36px;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .trend-card__unit {
    font-size: 13px;
    color: #64748b;
  }
  .trend-card__delta {
    font-size: 13px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    font-weight: 500;
  }
  .trend-card__delta-arrow { font-size: 11px; }
  .trend-card__delta--bad { color: #ef4444; }
  .trend-card__delta--good { color: #22c55e; }
  .trend-card__delta--neutral { color: #64748b; }
  .trend-card__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .trend-card__source {
    font-size: 11px;
    color: #64748b;
    text-decoration: underline;
    text-decoration-color: #cbd5e1;
  }
  .trend-card__source:hover {
    color: #0f172a;
    text-decoration-color: #94a3b8;
  }
  .trend-card__caveat {
    font-size: 12px;
    color: #64748b;
    font-style: italic;
    line-height: 1.45;
    margin: 0;
  }
</style>

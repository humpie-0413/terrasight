---
/**
 * BlockRenderer: dispatcher for a single ReportBlock.
 *
 * Responsibilities:
 *  - Renders the outer <section> with anchor id
 *  - Header: <h2>, TrustBadge, and (if non-ok) a StatusPill
 *  - Dispatches body to the right block component keyed on block.id
 *  - After body, renders citations list
 *  - Renders mandatory disclaimers (notes[]) with ⚠️ prefix —
 *    NEVER omit these per report-block policy.
 *
 * Note: the 2 optional blocks handled by Agent 2 (city_comparison,
 * related_cities) get a neutral fallback — Agent 2's page owns their
 * rendering, so if this dispatcher is ever passed one we render
 * prose + citations + notes as-is and let the page layout override.
 */
import type { ReportBlock } from '@terrasight/schemas';
import { TrustBadge, StatusPill } from '@terrasight/ui';

import AirQualityBlock from './blocks/AirQualityBlock.astro';
import ClimateLocallyBlock from './blocks/ClimateLocallyBlock.astro';
import HazardsDisastersBlock from './blocks/HazardsDisastersBlock.astro';
import WaterBlock from './blocks/WaterBlock.astro';
import IndustrialEmissionsBlock from './blocks/IndustrialEmissionsBlock.astro';
import SiteCleanupBlock from './blocks/SiteCleanupBlock.astro';
import PopulationExposureBlock from './blocks/PopulationExposureBlock.astro';
import MethodologyBlock from './blocks/MethodologyBlock.astro';
import PfasMonitoringBlock from './blocks/PfasMonitoringBlock.astro';
import CoastalConditionsBlock from './blocks/CoastalConditionsBlock.astro';
import DisasterHistoryDetailedBlock from './blocks/DisasterHistoryDetailedBlock.astro';
import NoData from './NoData.astro';

export interface Props {
  block: ReportBlock;
}

const { block } = Astro.props;
const anchorId = `block-${block.id}`;
---

<section id={anchorId} class="report-block" aria-labelledby={`${anchorId}-title`}>
  <header class="report-block__header">
    <h2 id={`${anchorId}-title`} class="report-block__title">{block.title}</h2>
    <div class="report-block__tags">
      <TrustBadge tag={block.trustTag} />
      {block.status !== 'ok' ? <StatusPill status={block.status} /> : null}
    </div>
  </header>

  <div class="report-block__body">
    {block.id === 'air_quality' ? (
      <AirQualityBlock block={block} />
    ) : block.id === 'climate_locally' ? (
      <ClimateLocallyBlock block={block} />
    ) : block.id === 'hazards_disasters' ? (
      <HazardsDisastersBlock block={block} />
    ) : block.id === 'water' ? (
      <WaterBlock block={block} />
    ) : block.id === 'industrial_emissions' ? (
      <IndustrialEmissionsBlock block={block} />
    ) : block.id === 'site_cleanup' ? (
      <SiteCleanupBlock block={block} />
    ) : block.id === 'population_exposure' ? (
      <PopulationExposureBlock block={block} />
    ) : block.id === 'methodology' ? (
      <MethodologyBlock block={block} />
    ) : block.id === 'pfas_monitoring' ? (
      <PfasMonitoringBlock block={block} />
    ) : block.id === 'coastal_conditions' ? (
      <CoastalConditionsBlock block={block} />
    ) : block.id === 'disaster_history_detailed' ? (
      <DisasterHistoryDetailedBlock block={block} />
    ) : (
      // Fallback: external/sidebar blocks (city_comparison, related_cities)
      // or any future id. Render body prose or NoData depending on status.
      block.status === 'ok' ? (
        <p class="report-block__prose">{block.body}</p>
      ) : (
        <NoData block={block} />
      )
    )}
  </div>

  {block.citations.length > 0 ? (
    <footer class="report-block__footer">
      <h3 class="report-block__footer-label">Sources</h3>
      <ul class="citations">
        {block.citations.map((c) => (
          <li class="citations__item">
            <a class="citations__link" href={c.url} target="_blank" rel="noopener noreferrer">
              {c.label}
            </a>
          </li>
        ))}
      </ul>
    </footer>
  ) : null}

  {block.notes.length > 0 ? (
    <ul class="disclaimers" aria-label={`${block.title} caveats`}>
      {block.notes.map((n) => (
        <li class="disclaimers__item">
          <span class="disclaimers__icon" aria-hidden="true">⚠️</span>
          <span class="disclaimers__text">{n}</span>
        </li>
      ))}
    </ul>
  ) : null}
</section>

<style>
  .report-block {
    padding: 28px 0;
    border-bottom: 1px solid #e2e8f0;
  }
  .report-block:last-child {
    border-bottom: none;
  }

  .report-block__header {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .report-block__title {
    font-size: 1.375rem;
    font-weight: 600;
    color: #0f172a;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .report-block__tags {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .report-block__body {
    margin: 0 0 16px;
  }
  .report-block__prose {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #334155;
    margin: 0;
  }

  .report-block__footer {
    margin-top: 16px;
  }
  .report-block__footer-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #64748b;
    margin: 0 0 6px;
  }
  .citations {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
  }
  .citations__item {
    font-size: 0.8125rem;
  }
  .citations__link {
    color: #1d4ed8;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .citations__link:hover {
    color: #1e40af;
  }

  .disclaimers {
    list-style: none;
    padding: 0;
    margin: 14px 0 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .disclaimers__item {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    font-size: 0.75rem;
    color: #64748b;
    font-style: italic;
    line-height: 1.4;
  }
  .disclaimers__icon {
    font-style: normal;
    flex-shrink: 0;
    line-height: 1.4;
  }
  .disclaimers__text {
    flex: 1;
  }

  @media (max-width: 640px) {
    .report-block__header {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
    }
  }
</style>

---
/**
 * Drinking Water & Surface Quality body component.
 *
 * Sources: EPA SDWIS (drinking water violations), USGS/EPA Water
 * Quality Portal (ambient samples).
 *
 * Block-specific data shape (when status === 'ok'):
 *   {
 *     systems?: Array<{ pwsid?: string; name?: string; population_served?: number }>
 *     violations?: Array<{ type?: string; date?: string; severity?: string }>
 *     wqp_sample_count?: number;
 *   }
 */
import type { ReportBlock } from '@terrasight/schemas';
import NoData from '../NoData.astro';
import MetricsTable from '../MetricsTable.astro';

export interface Props {
  block: ReportBlock;
}

const { block } = Astro.props;

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const data = (block.data ?? {}) as any;

type SystemEntry = { pwsid?: string; name?: string; population_served?: number };
type ViolationEntry = { type?: string; date?: string; severity?: string };

const systems: SystemEntry[] = Array.isArray(data.systems) ? data.systems.slice(0, 5) : [];
const violations: ViolationEntry[] = Array.isArray(data.violations)
  ? data.violations.slice(0, 5)
  : [];
const wqpSampleCount: number | undefined =
  typeof data.wqp_sample_count === 'number' ? data.wqp_sample_count : undefined;
---

{block.status !== 'ok' ? (
  <NoData block={block} />
) : (
  <div class="block-body">
    <p class="block-body__prose">{block.body}</p>
    <MetricsTable metrics={block.metrics} fallbackTag={block.trustTag} />

    {systems.length > 0 ? (
      <div class="block-body__subsection">
        <h3 class="block-body__subtitle">Notable public water systems</h3>
        <table class="simple-table">
          <thead>
            <tr>
              <th scope="col">System</th>
              <th scope="col">PWSID</th>
              <th scope="col">Population served</th>
            </tr>
          </thead>
          <tbody>
            {systems.map((s) => (
              <tr>
                <td>{s.name ?? '—'}</td>
                <td><code>{s.pwsid ?? '—'}</code></td>
                <td>{s.population_served !== undefined ? s.population_served.toLocaleString() : '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : null}

    {violations.length > 0 ? (
      <div class="block-body__subsection">
        <h3 class="block-body__subtitle">Recent SDWIS violations</h3>
        <ul class="violations-list">
          {violations.map((v) => (
            <li>
              <span class="violations-list__type">{v.type ?? 'Violation'}</span>
              {v.date ? <span class="violations-list__date">{v.date}</span> : null}
              {v.severity ? <span class="violations-list__severity">{v.severity}</span> : null}
            </li>
          ))}
        </ul>
      </div>
    ) : null}

    {wqpSampleCount !== undefined ? (
      <p class="block-body__footnote">
        Water Quality Portal samples (discrete): <strong>{wqpSampleCount.toLocaleString()}</strong>
      </p>
    ) : null}
  </div>
)}

<style>
  .block-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .block-body__prose {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #334155;
    margin: 0;
  }
  .block-body__subsection {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .block-body__subtitle {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 4px 0 0;
  }
  .block-body__footnote {
    font-size: 0.8125rem;
    color: #64748b;
    margin: 0;
  }
  .block-body__footnote strong {
    color: #0f172a;
    font-variant-numeric: tabular-nums;
  }
  .simple-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .simple-table thead th {
    text-align: left;
    font-weight: 600;
    color: #475569;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 8px 12px;
    border-bottom: 1px solid #e2e8f0;
    background: #f8fafc;
  }
  .simple-table tbody td {
    padding: 8px 12px;
    border-bottom: 1px solid #f1f5f9;
    color: #0f172a;
  }
  .simple-table tbody tr:last-child td {
    border-bottom: none;
  }
  .simple-table code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8125rem;
    color: #475569;
    background: #f1f5f9;
    padding: 1px 6px;
    border-radius: 4px;
  }
  .violations-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .violations-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.875rem;
    padding: 8px 12px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 6px;
  }
  .violations-list__type {
    color: #991b1b;
    font-weight: 600;
  }
  .violations-list__date {
    color: #64748b;
    font-size: 0.8125rem;
  }
  .violations-list__severity {
    color: #475569;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-left: auto;
  }
</style>

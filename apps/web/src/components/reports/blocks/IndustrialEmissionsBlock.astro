---
/**
 * Industrial & Emissions body component.
 *
 * Sources: EPA TRI (Toxics Release Inventory), EPA GHGRP.
 *
 * Block-specific data shape (when status === 'ok'):
 *   {
 *     top_emitters?: Array<{
 *       facility_name?: string;
 *       name?: string;
 *       lbs?: number;        // TRI (pounds released)
 *       tons?: number;       // GHGRP (metric tons CO2e)
 *       unit?: string;
 *       amount?: number;
 *     }>
 *   }
 */
import type { ReportBlock } from '@terrasight/schemas';
import NoData from '../NoData.astro';
import MetricsTable from '../MetricsTable.astro';

export interface Props {
  block: ReportBlock;
}

const { block } = Astro.props;

type Emitter = {
  facility_name?: string;
  name?: string;
  lbs?: number;
  tons?: number;
  unit?: string;
  amount?: number;
};

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const data = (block.data ?? {}) as any;
const topEmitters: Emitter[] = Array.isArray(data.top_emitters)
  ? data.top_emitters.slice(0, 5)
  : [];

function displayAmount(e: Emitter): { value: string; unit: string } {
  if (typeof e.lbs === 'number') return { value: e.lbs.toLocaleString(), unit: 'lbs' };
  if (typeof e.tons === 'number') return { value: e.tons.toLocaleString(), unit: 'metric tons CO2e' };
  if (typeof e.amount === 'number') return { value: e.amount.toLocaleString(), unit: e.unit ?? '' };
  return { value: '—', unit: '' };
}
---

{block.status !== 'ok' ? (
  <NoData block={block} />
) : (
  <div class="block-body">
    <p class="block-body__prose">{block.body}</p>
    <MetricsTable metrics={block.metrics} fallbackTag={block.trustTag} />

    {topEmitters.length > 0 ? (
      <div class="block-body__subsection">
        <h3 class="block-body__subtitle">Top reporting facilities</h3>
        <table class="simple-table">
          <thead>
            <tr>
              <th scope="col">Facility</th>
              <th scope="col">Reported amount</th>
            </tr>
          </thead>
          <tbody>
            {topEmitters.map((f) => {
              const { value, unit } = displayAmount(f);
              return (
                <tr>
                  <td>{f.facility_name ?? f.name ?? '—'}</td>
                  <td class="amount">
                    <strong>{value}</strong>
                    {unit ? <span class="amount__unit">{unit}</span> : null}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    ) : null}
  </div>
)}

<style>
  .block-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .block-body__prose {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #334155;
    margin: 0;
  }
  .block-body__subsection {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .block-body__subtitle {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 4px 0 0;
  }
  .simple-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .simple-table thead th {
    text-align: left;
    font-weight: 600;
    color: #475569;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 8px 12px;
    border-bottom: 1px solid #e2e8f0;
    background: #f8fafc;
  }
  .simple-table tbody td {
    padding: 8px 12px;
    border-bottom: 1px solid #f1f5f9;
    color: #0f172a;
  }
  .simple-table tbody tr:last-child td {
    border-bottom: none;
  }
  .amount strong {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .amount__unit {
    color: #64748b;
    font-size: 0.8125rem;
    margin-left: 4px;
  }
</style>

---
/**
 * Contaminated Sites & Cleanup body component.
 *
 * Sources: Superfund NPL, EPA ACRES (Brownfields), RCRA Info.
 *
 * Block-specific data shape (when status === 'ok'):
 *   {
 *     superfund_sites?: number | Array<unknown>;
 *     brownfields_sites?: number | Array<unknown>;
 *     rcra_sites?: number | Array<unknown>;
 *   }
 *
 * Landmine: some producers emit counts as numbers, others as arrays.
 * Normalize to a number before rendering.
 */
import type { ReportBlock } from '@terrasight/schemas';
import NoData from '../NoData.astro';
import MetricsTable from '../MetricsTable.astro';

export interface Props {
  block: ReportBlock;
}

const { block } = Astro.props;

function toCount(v: unknown): number | undefined {
  if (typeof v === 'number') return v;
  if (Array.isArray(v)) return v.length;
  return undefined;
}

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const data = (block.data ?? {}) as any;
const superfund = toCount(data.superfund_sites);
const brownfields = toCount(data.brownfields_sites);
const rcra = toCount(data.rcra_sites);

const tiles: Array<{ label: string; count: number | undefined; hint: string }> = [
  { label: 'Superfund NPL', count: superfund, hint: 'National Priorities List' },
  { label: 'Brownfields', count: brownfields, hint: 'EPA ACRES' },
  { label: 'RCRA TSDFs', count: rcra, hint: 'Hazardous waste handlers' },
];
const hasAnyTile = tiles.some((t) => t.count !== undefined);
---

{block.status !== 'ok' ? (
  <NoData block={block} />
) : (
  <div class="block-body">
    <p class="block-body__prose">{block.body}</p>
    <MetricsTable metrics={block.metrics} fallbackTag={block.trustTag} />

    {hasAnyTile ? (
      <div class="site-tiles">
        {tiles.map((t) => (
          <div class="site-tile">
            <span class="site-tile__label">{t.label}</span>
            <span class="site-tile__count">
              {t.count !== undefined ? t.count.toLocaleString() : '—'}
            </span>
            <span class="site-tile__hint">{t.hint}</span>
          </div>
        ))}
      </div>
    ) : null}
  </div>
)}

<style>
  .block-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .block-body__prose {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #334155;
    margin: 0;
  }
  .site-tiles {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
  }
  .site-tile {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
  }
  .site-tile__label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #475569;
    font-weight: 600;
  }
  .site-tile__count {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
    font-variant-numeric: tabular-nums;
  }
  .site-tile__hint {
    font-size: 0.75rem;
    color: #64748b;
  }
</style>

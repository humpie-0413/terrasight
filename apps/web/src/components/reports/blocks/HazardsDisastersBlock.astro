---
/**
 * Disaster Exposure body component.
 *
 * Source: OpenFEMA disaster declarations (summary counts).
 *
 * Block-specific data shape (when status === 'ok'):
 *   {
 *     counts_by_type?: Record<string, number>;
 *     total_declarations?: number;
 *     window_years?: number;
 *   }
 */
import type { ReportBlock } from '@terrasight/schemas';
import NoData from '../NoData.astro';
import MetricsTable from '../MetricsTable.astro';

export interface Props {
  block: ReportBlock;
}

const { block } = Astro.props;

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const data = (block.data ?? {}) as any;
const rawCounts = data.counts_by_type;
const countsEntries: Array<[string, number]> =
  rawCounts && typeof rawCounts === 'object' && !Array.isArray(rawCounts)
    ? Object.entries(rawCounts as Record<string, unknown>)
        .filter(([, v]) => typeof v === 'number')
        .map(([k, v]) => [k, v as number])
        .sort((a, b) => b[1] - a[1])
        .slice(0, 5)
    : [];

const maxCount = countsEntries.length > 0 ? countsEntries[0][1] : 0;
---

{block.status !== 'ok' ? (
  <NoData block={block} />
) : (
  <div class="block-body">
    <p class="block-body__prose">{block.body}</p>
    <MetricsTable metrics={block.metrics} fallbackTag={block.trustTag} />

    {countsEntries.length > 0 ? (
      <div class="block-body__subsection">
        <h3 class="block-body__subtitle">Top incident types</h3>
        <ul class="bar-list">
          {countsEntries.map(([type, count]) => (
            <li class="bar-list__row">
              <span class="bar-list__label">{type}</span>
              <div class="bar-list__track" aria-hidden="true">
                <span
                  class="bar-list__fill"
                  style={`width:${maxCount > 0 ? (count / maxCount) * 100 : 0}%;`}
                ></span>
              </div>
              <span class="bar-list__count">{count.toLocaleString()}</span>
            </li>
          ))}
        </ul>
      </div>
    ) : null}
  </div>
)}

<style>
  .block-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .block-body__prose {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #334155;
    margin: 0;
  }
  .block-body__subsection {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .block-body__subtitle {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 4px 0 0;
  }
  .bar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .bar-list__row {
    display: grid;
    grid-template-columns: minmax(120px, 30%) 1fr auto;
    align-items: center;
    gap: 10px;
    font-size: 0.875rem;
  }
  .bar-list__label {
    color: #0f172a;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .bar-list__track {
    height: 8px;
    background: #f1f5f9;
    border-radius: 9999px;
    overflow: hidden;
  }
  .bar-list__fill {
    display: block;
    height: 100%;
    background: #fb923c;
    border-radius: 9999px;
  }
  .bar-list__count {
    font-variant-numeric: tabular-nums;
    color: #475569;
    font-size: 0.8125rem;
  }
</style>

---
/**
 * Disaster History Detailed body component (optional).
 *
 * Source: OpenFEMA disaster declarations (event-level).
 *
 * Block-specific data shape (when status === 'ok'):
 *   {
 *     events?: Array<{
 *       date?: string;               // ISO yyyy-mm-dd
 *       declaration_date?: string;
 *       type?: string;               // e.g. "Severe Storm"
 *       declaration_number?: string;
 *       declaration_title?: string;
 *       title?: string;
 *     }>
 *   }
 *
 * Render most-recent-first, capped at 10 rows.
 */
import type { ReportBlock } from '@terrasight/schemas';
import NoData from '../NoData.astro';
import MetricsTable from '../MetricsTable.astro';

export interface Props {
  block: ReportBlock;
}

const { block } = Astro.props;

type DisasterEvent = {
  date?: string;
  declaration_date?: string;
  type?: string;
  declaration_number?: string;
  declaration_title?: string;
  title?: string;
};

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const data = (block.data ?? {}) as any;
const rawEvents: DisasterEvent[] = Array.isArray(data.events) ? data.events : [];

function eventDate(e: DisasterEvent): string | undefined {
  return e.date ?? e.declaration_date;
}
function eventTitle(e: DisasterEvent): string {
  return e.declaration_title ?? e.title ?? e.type ?? 'Disaster declaration';
}

const events = [...rawEvents]
  .sort((a, b) => {
    const ad = eventDate(a) ?? '';
    const bd = eventDate(b) ?? '';
    return bd.localeCompare(ad);
  })
  .slice(0, 10);
---

{block.status !== 'ok' ? (
  <NoData block={block} />
) : (
  <div class="block-body">
    <p class="block-body__prose">{block.body}</p>
    <MetricsTable metrics={block.metrics} fallbackTag={block.trustTag} />

    {events.length > 0 ? (
      <ol class="event-list">
        {events.map((e) => (
          <li class="event-list__row">
            <div class="event-list__head">
              <span class="event-list__date">{eventDate(e) ?? '—'}</span>
              {e.declaration_number ? (
                <code class="event-list__num">{e.declaration_number}</code>
              ) : null}
            </div>
            <div class="event-list__title">{eventTitle(e)}</div>
            {e.type && e.type !== eventTitle(e) ? (
              <div class="event-list__type">{e.type}</div>
            ) : null}
          </li>
        ))}
      </ol>
    ) : null}
  </div>
)}

<style>
  .block-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .block-body__prose {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #334155;
    margin: 0;
  }
  .event-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .event-list__row {
    padding: 10px 14px;
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: 6px;
  }
  .event-list__head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 4px;
  }
  .event-list__date {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8125rem;
    color: #9a3412;
    font-weight: 600;
  }
  .event-list__num {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.75rem;
    color: #64748b;
    background: rgba(255, 255, 255, 0.7);
    padding: 1px 6px;
    border-radius: 4px;
  }
  .event-list__title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #7c2d12;
  }
  .event-list__type {
    font-size: 0.8125rem;
    color: #9a3412;
    margin-top: 2px;
  }
</style>

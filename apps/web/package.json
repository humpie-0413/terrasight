{
  "name": "web",
  "type": "module",
  "version": "0.2.0",
  "scripts": {
    "setup-cesium": "node -e \"require('fs').cpSync('node_modules/cesium/Build/Cesium','public/cesium',{recursive:true,force:true})\"",
    "predev": "pnpm run setup-cesium",
    "prebuild": "pnpm run setup-cesium",
    "prepreview": "pnpm run setup-cesium",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "tsc --noEmit",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/node": "^8.3.3",
    "@astrojs/react": "^3.6.2",
    "@astrojs/sitemap": "^3.2.1",
    "@terrasight/schemas": "workspace:*",
    "@terrasight/ui": "workspace:*",
    "astro": "^4.15.0",
    "cesium": "^1.140.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.9.3"
  }
}
